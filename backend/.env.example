APP_NAME=Room Booking System
APP_ENV=development
APP_PORT=8080
APP_URL=http://localhost:8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=JeffTheKiller
DB_NAME=room_booking_db
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Jakarta

JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_REMEMBER_ME_ACCESS_DAYS=7
JWT_REMEMBER_ME_REFRESH_DAYS=30

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept,Origin

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email_here
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM_NAME=Room Booking System
SMTP_FROM_EMAIL=your_email_here

DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# Feature Flags
# Register & local password flows are disabled in LDAP mode — keep these false.
# ENABLE_EMAIL_VERIFICATION=false
# ENABLE_OTP_LOGIN=false
# ENABLE_EMAIL_NOTIFICATIONS=false

# ─────────────────────────────────────────────────────────────────────────────
# LDAP / Active Directory Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Hostname or IP of your AD server
LDAP_HOST=ldap.perusahaan.com

# 389 = plain LDAP  |  636 = LDAPS (SSL)
LDAP_PORT=389

# Set to true if LDAP_PORT=636
LDAP_USE_SSL=false

# DEVELOPMENT ONLY — skip TLS certificate validation.
# Never set to true in production.
LDAP_INSECURE_SKIP_VERIFY=false

# Service account used by the application to *search* the directory.
# This account only needs read/search permission on BaseDN.
# Example for Active Directory:
#   cn=svc-roombooking,ou=Service Accounts,dc=perusahaan,dc=com
LDAP_BIND_DN=cn=svc-roombooking,ou=Service Accounts,dc=perusahaan,dc=com
LDAP_BIND_PASSWORD=ServiceAccountPassword

# Base DN — the root of the subtree to search for users
# Example: dc=perusahaan,dc=com
LDAP_BASE_DN=dc=perusahaan,dc=com

# LDAP search filter to locate a user.
# %s is replaced with the username extracted from the login email.
# Active Directory: (sAMAccountName=%s)
# OpenLDAP:         (uid=%s)
LDAP_USER_FILTER=(sAMAccountName=%s)

# AD attribute names
LDAP_ATTR_NAME=displayName
LDAP_ATTR_EMAIL=mail
LDAP_ATTR_DIVISION=department

# Fallback domain appended to username when the AD 'mail' attribute is empty.
# Example: john.doe → john.doe@perusahaan.com
LDAP_DEFAULT_EMAIL_DOMAIN=perusahaan.com

# Proxy (optional)
# TRUSTED_PROXIES=127.0.0.1,localhost