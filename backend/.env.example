# Application
APP_NAME=Room Booking System
APP_ENV=development
APP_PORT=8080
APP_URL=http://localhost:8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_username_here
DB_PASSWORD=your_password_here
DB_NAME=your_database_name_here
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Jakarta

# JWT Configuration
JWT_SECRET=jwt_secret_key_here
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_REMEMBER_ME_ACCESS_DAYS=7
JWT_REMEMBER_ME_REFRESH_DAYS=30

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept,Origin

# Email Configuration (Optional - untuk nanti)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Room Booking System
SMTP_FROM_EMAIL=noreply@roombooking.com

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# Rate Limiting (untuk nanti)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION=1m

# # Feature Flags
# ENABLE_EMAIL_VERIFICATION=false
# ENABLE_EMAIL_NOTIFICATIONS=false

## For Proxy
# TRUSTED_PROXIES=127.0.0.1,localhost