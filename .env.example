# PostgreSQL
POSTGRES_USER=your_postgres_user_here
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=room_booking_db

# Application
APP_NAME=Room Booking System
APP_ENV=production
APP_PORT=8080
APP_URL=http://localhost:8080

# Database Connection
DB_HOST=postgres
DB_PORT=5432
DB_USER=your_database_user_here
DB_PASSWORD=your_database_password_here
DB_NAME=room_booking_db
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Jakarta

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_REMEMBER_ME_ACCESS_DAYS=7
JWT_REMEMBER_ME_REFRESH_DAYS=30

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept,Origin

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=Room Booking System
SMTP_FROM_EMAIL=noreply@roombooking.com

# # Feature Flags
# ENABLE_EMAIL_VERIFICATION=false
# ENABLE_EMAIL_NOTIFICATIONS=false

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

## For Proxy
# TRUSTED_PROXIES=127.0.0.1,localhost